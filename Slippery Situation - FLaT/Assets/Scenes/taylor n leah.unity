  textIcon: {fileID: 1149588582}
  textComponent: {fileID: 1989852373}
  lines:
  - hi im olive, leah's testing dialogue buddy
  - im here to show u a tutorial of how things work on this template level
  - sad that ur stuck on this platform innit? but hey that drink there looks a little
    "pop" - ish.
  - check out that pop
  - i wonder if you will "pop" up there
  - my little soda pop
  - go explore little guy
  secondPart: 3
  textSpeed: 0.03
  talkingToggle: 0
  dissapearing: 0
